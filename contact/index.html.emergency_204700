nav a:hover{text-decoration:underline;color:var(--accent)}
.wrap{padding:20px;max-width:900px;margin:auto}
.panel{border:1px solid rgba(116,255,207,.35);border-radius:10px;padding:14px 16px;background:rgba(12,24,28,.8);margin:10px 0}
.item{display:inline-flex;align-items:center;gap:8px;margin:6px 10px 6px 0;padding:6px 10px;border:1px solid rgba(116,255,207,.35);border-radius:999px;color:var(--muted);text-decoration:none}
