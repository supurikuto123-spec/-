label{font-size:12px;color:var(--muted)}
.req{color:var(--accent);margin-left:6px}
input[type="email"],input[type="text"],textarea,select{
  background:var(--term);color:var(--text);border:1px solid rgba(116,255,207,.35);
  border-radius:8px;padding:10px;font-family:inherit;font-size:14px;outline:none
}
input:focus,textarea:focus,select:focus{border-color:rgba(116,255,207,.7)}
textarea{min-height:140px;resize:vertical}
.controls{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.btn{
  appearance:none;background:transparent;color:var(--accent);
  border:1px solid rgba(116,255,207,.6);padding:10px 14px;border-radius:10px;
  cursor:pointer;font-weight:700
}
.btn:hover{background:rgba(116,255,207,.08)}
.btn[disabled]{opacity:.6;cursor:not-allowed}
.note{font-size:12px;color:var(--muted)}
.status{font-size:13px}
.success{color:#8affcb}
.error{color:#ff9aa2}
.hidden{display:none}
.hr{height:1px;background:rgba(116,255,207,.2);margin:8px 0}
.small{font-size:12px;color:var(--muted)}
/* honeypot */
.hp{position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden}
    /* モバイル最適化 */
    @media (max-width: 860px){
      .nav{display:none}
      .menu-btn{display:inline-block}
      .notice{gap:6px}
      h1{font-size:15px}
      .badge{padding:3px 7px;font-size:11px}
    }
</style>
