  <div class="panel" id="contact-panel">
    <h2 style="font-size:16px;margin:0 0 6px;color:var(--accent)">お問い合わせフォーム</h2>
    <div class="small">※「返信が不要」の場合はメールアドレスは空欄で送信できます。</div>
    <div class="hr"></div>

    <form id="contact-form" class="form" novalidate>
      <!-- honeypot: ここが埋まっていたら bot とみなす -->
      <div class="hp">
        <label>Leave this field empty<input type="text" name="website" autocomplete="off"></label>
      </div>

      <div class="field">
        <label for="need-reply">返信が必要ですか？ <span class="req">(必須)</span></label>
        <select id="need-reply" name="needReply" required>
          <option value="" disabled selected>選択してください</option>
          <option value="yes">はい（返信希望）</option>
          <option value="no">いいえ（返信不要）</option>
        </select>
      </div>

      <div class="field">
        <label for="email">返信用メールアドレス <span id="email-req" class="req hidden">(必須)</span></label>
        <input id="email" name="email" type="email" placeholder="you@example.com" inputmode="email" autocomplete="email">
        <div class="note">※「返信が必要」を選んだ場合のみ必須です。</div>
      </div>

      <div class="field">
        <label for="title">タイトル（任意）</label>
        <input id="title" name="title" type="text" maxlength="120" placeholder="例）アカウントに関するお問い合わせ">
      </div>

      <div class="field">
        <label for="body">本文 <span class="req">(必須)</span></label>
        <textarea id="body" name="body" required placeholder="できるだけ詳しくご記入ください。"></textarea>
      </div>

      <div class="controls">
        <button type="submit" id="submit-btn" class="btn">送信</button>
        <span id="status" class="status"></span>
      </div>
      <div class="small">送信内容はサポート用の Discord チャンネルに転送されます。個人情報は必要最小限の記入にご協力ください。</div>
    </form>
  </div>
