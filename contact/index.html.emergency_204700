<noscript>
  <div class="wrap">
    <div class="panel error">このフォームを利用するには JavaScript を有効にしてください。</div>
  </div>
</noscript>

<script>
(() => {
 const WEBHOOK_URL = "/contact/contact-send.php"; // プロキシを叩く
  const form = document.getElementById("contact-form");
  const needReply = document.getElementById("need-reply");
  const email = document.getElementById("email");
  const emailReq = document.getElementById("email-req");
  const title = document.getElementById("title");
  const body = document.getElementById("body");
  const submitBtn = document.getElementById("submit-btn");
  const statusEl = document.getElementById("status");

  // 返信要否によって email を必須化
  function syncEmailRequirement() {
    const required = needReply.value === "yes";
    email.required = required;
    emailReq.classList.toggle("hidden", !required);
  }
  needReply.addEventListener("change", syncEmailRequirement);

  // 簡易メール検証
  function isValidEmail(v) {
    if (!v) return false;
    // RFC完全準拠ではないが実用的な軽量チェック
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
  }

  async function postToDiscord(payload) {
    // Discord はレート制限 (HTTP 429) があるので簡易リトライ
    const maxRetries = 2;
    let attempt = 0;
    while (attempt <= maxRetries) {
      const res = await fetch(WEBHOOK_URL, {
        method: "POST",
        mode: "cors",
        headers: {"Content-Type": "application/json"},
        body: JSON.stringify(payload)
      });
      if (res.status === 429) {
        // リトライ-アフター秒（ミリ秒）を待つ
        const data = await res.json().catch(() => ({}));
        const wait = Number(data.retry_after ? data.retry_after * 1000 : 1000);
        await new Promise(r => setTimeout(r, wait));
        attempt++;
        continue;
      }
      if (!res.ok) {
        const txt = await res.text().catch(() => "");
        throw new Error("送信に失敗しました (" + res.status + ") " + txt);
      }
      return true;
    }
    throw new Error("送信が混み合っています。しばらくしてからお試しください。");
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    statusEl.textContent = "";
    statusEl.className = "status";
    syncEmailRequirement();

    // honeypot
    const hp = form.querySelector('input[name="website"]');
    if (hp && hp.value) {
      // bot とみなして成功扱いにして黙って返す
      form.reset();
      syncEmailRequirement();
      statusEl.textContent = "送信しました。";
      statusEl.classList.add("success");
      return;
    }

    // 必須チェック
    if (!needReply.value) {
      statusEl.textContent = "「返信が必要ですか？」を選択してください。";
      statusEl.classList.add("error");
      return;
    }
    if (!body.value.trim()) {
      statusEl.textContent = "本文を入力してください。";
      statusEl.classList.add("error");
      return;
    }
    if (needReply.value === "yes" && !isValidEmail(email.value.trim())) {
      statusEl.textContent = "有効なメールアドレスを入力してください。";
      statusEl.classList.add("error");
      return;
    }

    // Discord 表示用のメッセージを組み立て
    const now = new Date();
    const pageUrl = location.href;
    const ua = navigator.userAgent;

    // 本文は content / embeds どちらでもOK。ここでは embeds を使って見やすく。
    const embed = {
      title: (title.value.trim() || "お問い合わせ"),
      color: 0x74ffcf,
      fields: [
        { name: "返信が必要", value: (needReply.value === "yes" ? "はい" : "いいえ"), inline: true },
        { name: "返信用メール", value: (email.value.trim() || "（未入力）"), inline: true },
        { name: "本文", value: body.value.trim().slice(0, 5900) }, // Discord の embed.description/fieldsは 6000字 制限対策
        { name: "ページ", value: pageUrl, inline: false },
        { name: "UA", value: ua.slice(0, 1000), inline: false }
      ],
      footer: { text: "tomy634.com | " + now.toLocaleString() }
    };

    const payload = {
      username: "tomy634.com Contact",
      content: null, // embeds中心で送る
      embeds: [embed],
      allowed_mentions: { parse: [] } // 誤メンション防止
    };

    submitBtn.disabled = true;
    submitBtn.textContent = "送信中…";

    try {
      await postToDiscord(payload);
      statusEl.textContent = "送信しました。ありがとうございました！";
      statusEl.classList.add("success");
      form.reset();
      syncEmailRequirement();
    } catch (err) {
      console.error(err);
      statusEl.textContent = String(err.message || err) || "送信に失敗しました。";
      statusEl.classList.add("error");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "送信";
    }
  });

  // 初期化
  syncEmailRequirement();
})();
</script>
