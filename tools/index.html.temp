<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>ツール | tomy634.com</title>
  <meta name="description" content="tomy634.com で利用できる各種ツールへのリンク一覧ページです。"/>
  <meta name="robots" content="index,follow"/>
  <meta property="og:type" content="website"/>
  <meta property="og:title" content="ツール | tomy634.com"/>
  <meta property="og:description" content="tomy634.com 上のツール一覧ページです。"/>
  <meta property="og:url" content="https://tomy634.com/tools/"/>
  <meta property="og:site_name" content="tomy634.com"/>
  <meta property="og:locale" content="ja_JP"/>
  <meta name="twitter:card" content="summary"/>
  <style>
    :root{
      --bg:#0a0f12;--term:#0d1618;--text:#d7ffe8;--accent:#74ffcf;--muted:#89bfa6;
      --danger:#ff7189;--ok:#7dffb3;--warn:#ffd569;--link:#4dabff;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:ui-monospace,Consolas,monospace;
      background:var(--bg);
      color:var(--text);
    }

    /* 共通ヘッダ（通知バッジ／サポート表記なし版） */
    header{
      position:sticky;
      top:0;z-index:10;
      background:rgba(10,15,18,.95);
      backdrop-filter:saturate(120%) blur(6px);
      border-bottom:1px solid rgba(116,255,207,.2);
      padding:10px 12px;
    }
    .bar{display:flex;align-items:center;gap:10px}
    .brand{display:flex;align-items:center;gap:10px;min-width:0;flex:1}
    .logo{
      width:34px;height:34px;
      border:1px solid var(--accent);
      border-radius:8px;
      display:grid;place-items:center;
      box-shadow:0 0 12px rgba(116,255,207,.3);
    }
    .logo::after{content:"$";color:var(--accent);font-weight:700}
    h1{
      font-size:16px;margin:0;color:var(--accent);
      white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
    }

    .navwrap{display:flex;align-items:center;gap:8px}
    .nav{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
    .nav a{
      color:var(--muted);text-decoration:none;
      font-size:13px;white-space:nowrap;
    }
    .nav a:hover{text-decoration:underline;color:var(--accent)}
    .menu-btn{
      display:none;
      border:1px solid rgba(116,255,207,.6);
      color:var(--accent);background:transparent;
      border-radius:8px;padding:6px 10px;font-size:12px;
    }
    .menu{
      display:none;
      padding:8px 10px;
      border-top:1px solid rgba(116,255,207,.2);
    }
    .menu a{
      display:block;
      padding:8px 4px;
      color:var(--muted);
      text-decoration:none;
      font-size:14px;
    }
    .menu a:hover{color:var(--accent)}

    @media (max-width: 860px){
      .nav{display:none}
      .menu-btn{display:inline-block}
      h1{font-size:15px}
    }

    /* 本文（ツール一覧だけ。中身のツールUIはここに置かない） */
    .wrap{padding:20px;max-width:900px;margin:auto}
    h2{
      margin:0 0 10px;
      font-size:16px;
      color:var(--accent);
    }
    .section{
      border:1px solid rgba(116,255,207,.35);
      border-radius:10px;
      padding:14px 16px;
      background:rgba(12,24,28,.8);
      margin:8px 0;
    }
    ul.tools{
      list-style:none;
      margin:0;
      padding:0;
    }
    ul.tools li{
      margin:4px 0;
      font-size:13px;
      color:var(--muted);
    }
    ul.tools a{
      color:var(--link);
      text-decoration:none;
    }
    ul.tools a:hover{
      text-decoration:underline;
      color:var(--accent);
    }

    footer{
      border-top:1px solid rgba(116,255,207,.2);
      margin-top:24px;
      padding:12px 16px;
      color:var(--muted);
      font-size:12px;
      text-align:center;
    }
  </style>
</head>
<body>
<header>
  <div class="bar">
    <div class="brand">
      <div class="logo"></div>
      <h1>tomy634.com // ツール</h1>
    </div>
    <div class="navwrap">
      <nav class="nav" aria-label="メイン">
        <a href="/">ホーム</a>
        <a href="/blog">ブログ</a>
        <a href="/how-to-use">使い方</a>
        <a href="/faq">FAQ</a>
        <a href="/tools">ツール</a>
        <a href="/about">概要</a>
        <a href="/terms">利用規約</a>
        <a href="/privacy">プライバシー</a>
        <a href="/contact">お問い合わせ</a>
        <a href="/api">API</a>
      </nav>
      <button id="menu-toggle" class="menu-btn" type="button"
              aria-expanded="false" aria-controls="menu">メニュー</button>
    </div>
  </div>
  <div id="menu" class="menu" hidden>
    <a href="/">ホーム</a>
    <a href="/blog">ブログ</a>
    <a href="/how-to-use">使い方</a>
    <a href="/faq">FAQ</a>
    <a href="/tools">ツール</a>
    <a href="/about">概要</a>
    <a href="/terms">利用規約</a>
    <a href="/privacy">プライバシー</a>
    <a href="/contact">お問い合わせ</a>
    <a href="/api">API</a>
  </div>
</header>

<div class="wrap">
  <section class="section" aria-labelledby="tool-list">
    <h2 id="tool-list">ツール一覧</h2>
    <ul class="tools">
      <li>
        <a href="/tools/char-counter/">文字数カウンター</a>
      </li>
      <!-- 他のツールを追加する場合はここに <li> を増やす -->
    </ul>
  </section>
</div>

<footer>
  © tomy634.com
</footer>

<script>
(function(){
  'use strict';
  // ヘッダのスマホメニューだけ（他の挙動は一切無し）
  var btn  = document.getElementById('menu-toggle');
  var menu = document.getElementById('menu');
  if(!btn || !menu) return;

  function set(open){
    if(open){
      menu.hidden = false;
      menu.style.display = 'block';
      btn.setAttribute('aria-expanded','true');
    }else{
      menu.hidden = true;
      menu.style.display = 'none';
      btn.setAttribute('aria-expanded','false');
    }
  }

  btn.addEventListener('click', function(){
    var open = btn.getAttribute('aria-expanded') === 'true';
    set(!open);
  });
})();
</script>
</body>
</html>
