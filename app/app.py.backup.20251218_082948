# ---------- API v1: Box関連 ----------

@app.post("/api/v1/boxes")
def api_create_box_v1():
    """
    新しい一時メールアドレスを発行する。
    - ttl_days: 0 / 1 / 3 / 7
        0 = 1通でも届いたらアドレスごと自動削除（delete_on_first=True）
        1,3,7 = その日数を過ぎたらボックスごと削除対象
        未指定なら 1日 をデフォルトにする
    - max_messages: 上限（未指定なら 5 をデフォルトとする）

    レスポンス例:
    {
      "box_id": "sii3jux2ipw4",
      "email": "pwhnbzy0@tomy634.com",
      "ttl_days": 1,
      "delete_on_first": false,
      "max_messages": 5,
      "created_at": "...",
      "expires_at": "..."
    }
    """
    api_row, _ = require_api_key()  # APIキー & レート制限チェック

    data = request.json or {}
    ttl_days = data.get("ttl_days", 1)
    max_messages = data.get("max_messages")

    # ttl_days 正規化
    if ttl_days is None:
        ttl_days = 1
    try:
        ttl_days = int(ttl_days)
    except (TypeError, ValueError):
        ttl_days = 1

    if ttl_days not in (0, 1, 3, 7):
        # 不正値は1日に丸める
        ttl_days = 1

    delete_on_first = (ttl_days == 0)

    # max_messages デフォルト
    if max_messages is None:
        # いったん API 全体のデフォルトとして 5 を採用
        max_messages = 5
    else:
        try:
            max_messages = int(max_messages)
        except (TypeError, ValueError):
            max_messages = 5
        if max_messages <= 0:
            max_messages = 5

    created = now_utc()
    created_iso = created.isoformat()

    if ttl_days > 0:
        expires_at = (created + timedelta(days=ttl_days)).isoformat()
    else:
        expires_at = None

    db = get_db()
    local_part = gen_local_part()
    box_id = gen_box_id()

    db.execute(
        """
        INSERT INTO mailboxes
          (box_id, local_part, user_id, created_at, last_seen_at,
           ttl_days, delete_on_first, max_messages, expires_at)
        VALUES (?, ?, NULL, ?, ?, ?, ?, ?, ?)
        """,
        (
            box_id,
            local_part,
            created_iso,
            created_iso,
            ttl_days,
            1 if delete_on_first else 0,
            max_messages,
            expires_at,
        ),
    )
    db.commit()

    return jsonify({
        "box_id": box_id,
        "email": f"{local_part}@tomy634.com",
        "ttl_days": ttl_days,
        "delete_on_first": delete_on_first,
        "max_messages": max_messages,
        "created_at": created_iso,
        "expires_at": expires_at,
    }), 201

@app.get("/api/v1/boxes/<box_id>/messages")
def api_box_messages_v1(box_id):
    """
    対象ボックスのメール一覧を返す。
    query: ?limit=20 など
    レスポンス:
    {
      "box_id": "...",
      "messages": [
        {
          "id": 1,
          "box_id": "...",
          "from": "...",
          "subject": "...",
          "date": "...",
          "snippet": "..."
        },
        ...
      ]
    }
    """
    api_row, _ = require_api_key()  # APIキー & レート制限チェック

    db = get_db()
    cur = db.execute(
        "SELECT id, box_id, local_part, ttl_days, delete_on_first, "
        "       max_messages, expires_at "
        "FROM mailboxes WHERE box_id = ?",
        (box_id,),
    )
    box = cur.fetchone()
    if not box:
        abort(404, description="box not found")

    # 期限切れチェック（期限切れならここで削除＆404）
    ensure_box_not_expired(db, box)

    # ボックスの設定に基づいてクリーンアップ
    cleanup_messages_for_box(db, box)

    limit = request.args.get("limit", "20")
    try:
        limit = int(limit)
    except ValueError:
        limit = 20
    limit = max(1, min(100, limit))

    cur = db.execute(
        "SELECT id, from_addr, subject, body_text, received_at "
        "FROM messages WHERE mailbox_id = ? "
        "ORDER BY received_at DESC, id DESC "
        "LIMIT ?",
        (box["id"], limit),
    )
    rows = cur.fetchall()

    messages = []
    for r in rows:
        snippet = (r["body_text"] or "")[:200]
        messages.append({
            "id": r["id"],
            "box_id": box["box_id"],
            "from": r["from_addr"],
            "subject": r["subject"],
            "date": r["received_at"],
            "snippet": snippet,
        })

    return jsonify({
        "box_id": box["box_id"],
        "messages": messages,
    })

@app.delete("/api/v1/boxes/<box_id>")
def api_delete_box_v1(box_id):
    """
    ボックスごと削除（メールも全部削除）
    """
    api_row, _ = require_api_key()

    db = get_db()
    cur = db.execute("SELECT id FROM mailboxes WHERE box_id = ?", (box_id,))
    box = cur.fetchone()
    if not box:
        abort(404, description="box not found")

    mailbox_id = box["id"]
    db.execute("DELETE FROM messages WHERE mailbox_id = ?", (mailbox_id,))
    db.execute("DELETE FROM mailboxes WHERE id = ?", (mailbox_id,))
    db.commit()

    return jsonify({"ok": True, "box_id": box_id})

