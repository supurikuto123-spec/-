@app.get("/api/v1/messages/<int:message_id>")
def api_message_detail(message_id):
    """
    1件のメール詳細（本文プレーンテキスト＋メタデータ）。
    """
    api_row, _ = require_api_key()

    db = get_db()
    cur = db.execute(
        """
        SELECT m.id, m.mailbox_id, m.from_addr, m.subject, m.body_text,
               m.received_at,
               b.box_id, b.local_part
        FROM messages m
        JOIN mailboxes b ON b.id = m.mailbox_id
        WHERE m.id = ?
        """,
        (message_id,),
    )
    row = cur.fetchone()
    if not row:
        abort(404, description="message not found")

    email_addr = f"{row['local_part']}@tomy634.com"
    snippet = (row["body_text"] or "")[:200]

    return jsonify({
        "id": row["id"],
        "box_id": row["box_id"],
        "email": email_addr,
        "from": row["from_addr"],
        "subject": row["subject"],
        "date": row["received_at"],
        "snippet": snippet,
        "body_text": row["body_text"],
    })

@app.get("/api/v1/messages/<int:message_id>/text")
def api_message_text(message_id):
    """
    純粋なプレーンテキスト本文だけを返す。
    Content-Type: text/plain; charset=utf-8
    """
    api_row, _ = require_api_key()  # APIキー & レート制限チェック

    db = get_db()
    cur = db.execute(
        "SELECT body_text FROM messages WHERE id = ?",
        (message_id,),
    )
    row = cur.fetchone()
    if not row:
        abort(404, description="message not found")

    return Response(row["body_text"] or "", mimetype="text/plain; charset=utf-8")

@app.get("/api/v1/messages/<int:message_id>/source")
def api_message_source(message_id):
    """
    生のRFC822ソースを返す（raw_source列がある場合）。
    なければ 404。
    """
    api_row, _ = require_api_key()

    db = get_db()
    cur = db.execute(
        "SELECT raw_source FROM messages WHERE id = ?",
        (message_id,),
    )
    row = cur.fetchone()
    if not row or row["raw_source"] is None:
        abort(404, description="raw source not stored")

    return Response(row["raw_source"], mimetype="message/rfc822")

