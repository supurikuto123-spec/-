@app.get('/api/box/<box_id>/messages')
def box_messages_legacy(box_id):
    """
    旧UI用：指定ボックスIDのメッセージ一覧。
    """
    db = get_db()
    cur = db.execute('SELECT id, local_part FROM mailboxes WHERE box_id = ?', (box_id,))
    box = cur.fetchone()
    if not box:
        return jsonify({'error': 'box not found'}), 404

    cleanup_mailbox_legacy(db, box['id'])

    limit = request.args.get('limit', '20')
    try:
        limit = int(limit)
    except ValueError:
        limit = 20
    limit = max(1, min(100, limit))

    cur = db.execute(
        'SELECT id, from_addr, subject, body_text, received_at '
        'FROM messages WHERE mailbox_id = ? ORDER BY received_at DESC LIMIT ?',
        (box['id'], limit)
    )
    rows = cur.fetchall()
    msgs = []
    for r in rows:
        msgs.append({
            'id': r['id'],
            'from': r['from_addr'],
            'subject': r['subject'],
            'date': r['received_at'],
            'body': r['body_text'],
        })
    return jsonify(msgs)

